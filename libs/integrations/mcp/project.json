{
  "name": "mcp",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/integrations/mcp/src",
  "projectType": "library",
  "tags": ["scope:integration", "type:integration"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests",
        "cwd": "libs/integrations/mcp"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/integrations/mcp",
        "main": "libs/integrations/mcp/src/index.ts",
        "tsConfig": "libs/integrations/mcp/tsconfig.lib.json",
        "assets": ["libs/integrations/mcp/*.md"]
      }
    }
  }
}
